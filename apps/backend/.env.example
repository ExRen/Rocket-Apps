# ================================================================
# SERVER
# ================================================================
PORT=3001
NODE_ENV=development

# ================================================================
# DATABASE
# ================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/rocket_db"

# ================================================================
# JWT (JSON Web Token)
# ================================================================
JWT_SECRET="ganti-dengan-string-random-sangat-panjang-minimal-64-karakter"
JWT_EXPIRES_IN="8h"

# ================================================================
# MFA (Multi-Factor Authentication)
# ================================================================
MFA_ISSUER="ROCKET ASABRI"

# ================================================================
# SMTP — Email Notifikasi
# ================================================================
SMTP_HOST="mail.company.co.id"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@company.co.id"
SMTP_PASS="your-email-password"
SMTP_FROM="ROCKET <noreply@company.co.id>"

# ================================================================
# REDIS — Cache & Session
# ================================================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ================================================================
# FILE UPLOAD
# ================================================================
UPLOAD_DEST="./uploads"
MAX_FILE_SIZE_MB=10

# ================================================================
# FRONTEND URL (untuk CORS)
# ================================================================
FRONTEND_URL="http://localhost:5173"
